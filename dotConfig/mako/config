font=JetBrainsMono 12
background-color=#000000
text-color=#FFFFFF
border-color=#000000
default-timeout=5000
ignore-timeout=true
group-by=app-name
progress-color=over #E5542A
border-size=5
border-radius=15
padding=10
outer-margin=0
icons=1
max-icon-size=64
icon-path=~/GitHub/Chicago95

[urgency=low]
background-color=#36241B
text-color=#FFFFFF
default-timeout=3000

[urgency=normal]
background-color=#36241B
text-color=#FFFFFF

[urgency=critical]
background-color=#36241B
text-color=#FFFFFF
default-timeout=0

[mode=do-not-disturb]
invisible=true

[category=brightness]
text-color=#FFFFFF
progress-color=over #E5542A

[category=volume]
text-color=#1e2326
progress-color=over #E5542A
default-timeout=1700

[category=media]
icons=1
max-icon-size=64
background-color=#FFFFFF
text-color=#E5542A
default-timeout=2000
